---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillCategories = [
  {
    category: 'Backend & Core',
    icon: 'fas fa-server',
    items: ['Python', 'Django'],
  },
  {
    category: 'Frontend',
    icon: 'fas fa-palette',
    items: ['HTML', 'CSS'],
  },
  {
    category: 'Database',
    icon: 'fas fa-database',
    items: ['MySQL'],
  },
  {
    category: 'Tools & Cloud',
    icon: 'fas fa-tools',
    items: ['GitHub', 'AWS (Basics)'],
  },
];

const featuredSkill = {
  category: 'Specialized Frameworks & Deep Learning',
  icon: 'fas fa-brain',
  items: ['TensorFlow', 'Keras', 'GANs', 'OpenCV', 'UNet++'],
};
---

<BaseLayout title="Skills">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero-title">My Skills</h1>
      <p class="page-hero-description">Technologies and abilities I bring to the table</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- Featured full-width card -->
      <div class="skill-card skill-card-featured">
        <div class="skill-card-header">
          <i class={featuredSkill.icon}></i>
          <h3>{featuredSkill.category}</h3>
        </div>
        <div class="skill-tags">
          {featuredSkill.items.map((item) => (
            <span class="skill-tag">{item}</span>
          ))}
        </div>
      </div>

      <!-- Standard grid -->
      <div class="skills-grid">
        {skillCategories.map((skill) => (
          <div class="skill-card">
            <div class="skill-card-header">
              <i class={skill.icon}></i>
              <h3>{skill.category}</h3>
            </div>
            <div class="skill-tags">
              {skill.items.map((item) => (
                <span class="skill-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .skill-card-featured {
    margin-bottom: 1.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .skill-card:hover {
    border-color: var(--gold-border-strong);
    transform: translateY(-4px);
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-card-header i {
    font-size: 1.3rem;
    color: var(--gold);
  }

  .skill-card-header h3 {
    font-size: 1rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: var(--bg-dark);
    color: var(--text-secondary);
    padding: 6px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--border);
    transition: all 0.25s ease;
  }

  .skill-tag:hover {
    background: var(--gold-bg-strong);
    color: var(--gold);
    border-color: var(--gold-border-strong);
    transform: scale(1.05);
  }

  @media (max-width: 600px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-card-featured .skill-tags {
      justify-content: center;
    }
  }
</style>
