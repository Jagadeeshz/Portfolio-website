---
import BaseLayout from '../layouts/BaseLayout.astro';

const friends = [
  {
    name: 'Friend One',
    role: 'Collaborator & Buddy',
    bio: 'A great friend who shares the same passion for technology and creativity.',
  },
  {
    name: 'Friend Two',
    role: 'Study Partner',
    bio: 'We spent countless hours learning together and pushing each other to be better.',
  },
  {
    name: 'Friend Three',
    role: 'Tech Enthusiast',
    bio: 'Always excited to discuss new ideas, frameworks, and build cool stuff together.',
  },
  {
    name: 'Friend Four',
    role: 'Creative Mind',
    bio: 'An inspiring person with a unique perspective on art, design, and life.',
  },
  {
    name: 'Friend Five',
    role: 'Travel Companion',
    bio: 'Exploring new places and creating unforgettable memories together.',
  },
  {
    name: 'Friend Six',
    role: 'Mentor & Guide',
    bio: 'Someone who has always been there with valuable advice and encouragement.',
  },
];
---

<BaseLayout title="Friends">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero-title">Friends</h1>
      <p class="page-hero-description">The awesome people in my life</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {friends.map((friend) => (
          <div class="about-card" style="padding: 2rem 1.5rem; text-align: center;">
            <div style="width: 72px; height: 72px; border-radius: 50%; background: var(--gradient-primary); color: #000; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700; margin: 0 auto 1rem; box-shadow: 0 4px 15px rgba(218, 165, 32, 0.3);">
              {friend.name.charAt(0)}
            </div>
            <h3 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--text-primary);">{friend.name}</h3>
            <p style="font-size: 0.85rem; color: var(--gold); font-weight: 500; margin-bottom: 0.75rem;">{friend.role}</p>
            <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">{friend.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
