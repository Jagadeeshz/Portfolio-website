---
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryItems = [
  {
    src: '/images/gallery-1.jpg',
    title: 'Championship Reign',
    category: 'Leadership',
    layout: 'wide',
  },
  {
    src: '/images/profile.jpg',
    title: 'Ride with Intent',
    category: 'Lifestyle',
    layout: 'tall',
  },
  {
    src: '/images/gallery-2.jpg',
    title: 'Guntur Days',
    category: 'Squad',
    layout: 'standard',
  },
  {
    src: '/images/gallery-3.jpg',
    title: 'Spotlight Focus',
    category: 'Runway',
    layout: 'standard',
  },
  {
    src: '/images/gallery-4.jpg',
    title: 'Roots & Comfort',
    category: 'Anchor',
    layout: 'tall',
  },
  {
    src: '/images/gallery-5.jpg',
    title: 'The Campus Circle',
    category: 'Memories',
    layout: 'wide',
  },
];
---

<BaseLayout title="Gallery">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero-title">Gallery</h1>
      <p class="page-hero-description">Moments captured through my lens</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="masonry-grid">
        {galleryItems.map((item) => (
          <div class={`gallery-card gallery-card--${item.layout}`}>
            <div class="gallery-card-inner">
              <img
                src={item.src}
                alt={item.title}
                class="gallery-card-img"
                loading="lazy"
              />
              <div class="gallery-card-overlay">
                <span class="gallery-card-category">{item.category}</span>
                <h3 class="gallery-card-title">{item.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===========================================================
     MASONRY GRID
     =========================================================== */
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 260px;
    grid-auto-flow: dense;
    gap: 1.25rem;
  }

  /* -- Layout Variants -- */
  .gallery-card--wide {
    grid-column: span 2;
  }

  .gallery-card--tall {
    grid-row: span 2;
  }

  .gallery-card--standard {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* ===========================================================
     CARD CONTAINER
     =========================================================== */
  .gallery-card {
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    cursor: pointer;
    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .gallery-card:hover {
    border-color: var(--gold);
    box-shadow: 0 0 24px rgba(244, 196, 20, 0.15),
                0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .gallery-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* ===========================================================
     IMAGE
     =========================================================== */
  .gallery-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-card:hover .gallery-card-img {
    transform: scale(1.06);
  }

  /* ===========================================================
     SLIDING OVERLAY CAPTION
     =========================================================== */
  .gallery-card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(
      0deg,
      rgba(13, 13, 12, 0.92) 0%,
      rgba(13, 13, 12, 0.5) 40%,
      transparent 100%
    );
    transform: translateY(100%);
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-card:hover .gallery-card-overlay {
    transform: translateY(0);
  }

  .gallery-card-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(244, 196, 20, 0.1);
    border: 1px solid rgba(244, 196, 20, 0.25);
    border-radius: 4px;
    padding: 0.3rem 0.75rem;
    margin-bottom: 0.6rem;
    width: fit-content;
  }

  .gallery-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
  }

  /* ===========================================================
     RESPONSIVE — TABLET
     =========================================================== */
  @media (max-width: 900px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
  }

  /* ===========================================================
     RESPONSIVE — MOBILE
     =========================================================== */
  @media (max-width: 600px) {
    .masonry-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .gallery-card--wide,
    .gallery-card--tall,
    .gallery-card--standard {
      grid-column: span 1;
      grid-row: span 1;
    }

    .gallery-card-inner {
      aspect-ratio: 4 / 3;
    }

    .gallery-card--tall .gallery-card-inner {
      aspect-ratio: 3 / 4;
    }

    .gallery-card-overlay {
      transform: translateY(0);
    }

    .gallery-card-title {
      font-size: 1.1rem;
    }
  }
</style>
