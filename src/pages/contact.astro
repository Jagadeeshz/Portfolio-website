---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero-title">Get in Touch</h1>
      <p class="page-hero-description">I'd love to hear from you</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- CTA Callout -->
      <div class="cta-callout">
        <div class="cta-icon">
          <i class="fas fa-rocket"></i>
        </div>
        <h2 class="cta-title">LET'S BUILD SOMETHING GREAT</h2>
        <p class="cta-subtitle">
          Have an idea, an opportunity, or just want to connect? I'm always open to
          meaningful conversations and exciting collaborations.
        </p>
      </div>

      <!-- Contact Link Cards -->
      <div class="contact-cards-grid">
        <a href="mailto:tjagadeesh2903@gmail.com" class="contact-card">
          <span class="contact-card-icon">
            <i class="fas fa-envelope"></i>
          </span>
          <span class="contact-card-label">Email</span>
          <span class="contact-card-value">tjagadeesh2903@gmail.com</span>
        </a>

        <div class="contact-card contact-card-static">
          <span class="contact-card-icon">
            <i class="fas fa-map-marker-alt"></i>
          </span>
          <span class="contact-card-label">Location</span>
          <span class="contact-card-value">Hyderabad, India</span>
        </div>

        <a href="https://github.com/" target="_blank" rel="noopener noreferrer" class="contact-card">
          <span class="contact-card-icon">
            <i class="fab fa-github"></i>
          </span>
          <span class="contact-card-label">GitHub</span>
          <span class="contact-card-value">github.com/jagadeesh</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===========================================================
     CTA CALLOUT
     =========================================================== */
  .cta-callout {
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3.5rem 2.5rem;
    margin-bottom: 3rem;
    position: relative;
    overflow: hidden;
  }

  .cta-callout::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(244, 196, 20, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cta-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #0d0d0c;
    margin: 0 auto 1.5rem;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 30px rgba(244, 196, 20, 0.25);
  }

  .cta-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .cta-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ===========================================================
     CONTACT CARDS GRID
     =========================================================== */
  .contact-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.25rem 1.5rem;
    text-decoration: none;
    text-align: center;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .contact-card:hover {
    border-color: var(--gold-border-strong);
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 12px 36px rgba(244, 196, 20, 0.1);
  }

  .contact-card-static {
    cursor: default;
  }

  .contact-card-static:hover {
    transform: translateY(-3px);
  }

  .contact-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--gold-bg-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--gold);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .contact-card:hover .contact-card-icon {
    background: var(--gradient-primary);
    color: #0d0d0c;
    transform: scale(1.1);
  }

  .contact-card-label {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .contact-card-value {
    font-size: 0.9rem;
    color: var(--text-muted);
    word-break: break-all;
  }

  /* ===========================================================
     RESPONSIVE
     =========================================================== */
  @media (max-width: 768px) {
    .contact-cards-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .cta-title {
      font-size: 1.6rem;
      letter-spacing: 1px;
    }

    .cta-callout {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
