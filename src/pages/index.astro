---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="page-hero" style="min-height: 70vh; display: flex; align-items: center;">
    <div class="container">
      <h1 class="page-hero-title" style="font-size: 3.5rem;">Tanniru Jagadeesh Kumar</h1>
      <p class="page-hero-description" style="font-size: 1.4rem; margin-bottom: 2rem;">A passionate creator &amp; lifelong learner</p>
      <div style="text-align: center; display: flex; gap: 1rem; justify-content: center;">
        <a href="/about" class="about-card" style="display: inline-block; padding: 1rem 2.5rem; color: var(--gold); font-weight: bold; font-size: 1.1rem; text-decoration: none;">About Me</a>
        <a href="/projects" class="about-card" style="display: inline-block; padding: 1rem 2.5rem; color: var(--gold); font-weight: bold; font-size: 1.1rem; text-decoration: none;">My Projects</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-card">
        <h2 class="about-card-title">About Me</h2>
        <div class="image-content-wrapper left">
          <div class="image-container">
            <img src="/images/profile.jpg" alt="Tanniru Jagadeesh Kumar" onerror="this.style.display='none'" />
          </div>
          <div class="image-content">
            <div class="about-content">
              <p>Hi, I'm Jagadeesh — a quiet soul with a heart that feels deeply and a mind that dreams big. I believe the world changes not through loud voices, but through gentle hands that build, heal, and uplift. Technology, to me, is not just about code — it's about crafting experiences that make people feel seen, understood, and valued.</p>

              <p>I'm the kind of person who pauses to help, who listens more than I speak, and who finds joy in the success of others. In a world that often rewards toughness, I choose kindness — not as a weakness, but as my greatest strength.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">3+</div>
          <div class="stat-label">Years of Learning</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">20+</div>
          <div class="stat-label">Projects Built</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">10+</div>
          <div class="stat-label">Technologies</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">∞</div>
          <div class="stat-label">Curiosity</div>
        </div>
      </div>

      <div class="grid grid-2">
        <a href="/about" class="about-card" style="text-decoration: none; cursor: pointer; display: block; transition: all 0.3s ease;">
          <h3 style="color: var(--gold); font-size: 1.3rem; margin-bottom: 0.5rem;">About Me &rarr;</h3>
          <p style="color: var(--text-secondary);">My story, background, and what drives me.</p>
        </a>
        <a href="/projects" class="about-card" style="text-decoration: none; cursor: pointer; display: block; transition: all 0.3s ease;">
          <h3 style="color: var(--gold); font-size: 1.3rem; margin-bottom: 0.5rem;">Projects &rarr;</h3>
          <p style="color: var(--text-secondary);">Things I've built and contributed to.</p>
        </a>
        <a href="/skills" class="about-card" style="text-decoration: none; cursor: pointer; display: block; transition: all 0.3s ease;">
          <h3 style="color: var(--gold); font-size: 1.3rem; margin-bottom: 0.5rem;">Skills &rarr;</h3>
          <p style="color: var(--text-secondary);">Technologies and tools I work with.</p>
        </a>
        <a href="/experience" class="about-card" style="text-decoration: none; cursor: pointer; display: block; transition: all 0.3s ease;">
          <h3 style="color: var(--gold); font-size: 1.3rem; margin-bottom: 0.5rem;">Experience &rarr;</h3>
          <p style="color: var(--text-secondary);">My professional journey so far.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
