---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillCategories = [
  {
    category: 'Backend & Core',
    icon: 'fas fa-server',
    items: ['Python', 'Django'],
  },
  {
    category: 'Frontend',
    icon: 'fas fa-palette',
    items: ['HTML', 'CSS'],
  },
  {
    category: 'Database',
    icon: 'fas fa-database',
    items: ['MySQL'],
  },
  {
    category: 'Tools & Cloud',
    icon: 'fas fa-tools',
    items: ['GitHub', 'AWS (Basics)'],
  },
];

const featuredSkill = {
  category: 'Specialized Frameworks & Deep Learning',
  icon: 'fas fa-brain',
  items: ['TensorFlow', 'Keras', 'GANs', 'OpenCV', 'UNet++'],
};

const education = [
  {
    degree: 'Master of Computer Applications (MCA)',
    institution: "Vignan's University, Andhra Pradesh",
    period: '2022 — 2024',
    cgpa: '7.5',
  },
  {
    degree: 'Bachelor of Computer Science (Statistics)',
    institution: 'T.J.P.S Degree College, Andhra Pradesh',
    period: '2019 — 2022',
    cgpa: '6.92',
  },
];

const projectHighlights = [
  'Developed a novel salt segmentation framework by integrating GAN-based image enhancement with a modified UNet++ architecture for improved seismic image analysis.',
  'Achieved superior segmentation accuracy in identifying complex salt formations in seismic datasets.',
  'Contributed to improved subsurface characterization for applications in the oil and gas exploration sector.',
  'Optimized model performance through hyperparameter tuning and advanced data augmentation techniques, improving generalization on unseen seismic datasets.',
  'Reduced false positives in salt boundary detection by implementing a hybrid loss function combining Dice Loss and Binary Cross-Entropy (BCE).',
  'Implemented efficient preprocessing and normalization pipelines for seismic images to enhance feature extraction and model stability.',
  'Evaluated model performance using IoU, Dice Coefficient, Precision, and Recall metrics to ensure reliable segmentation accuracy.',
];

const techTags = ['Python', 'TensorFlow', 'Keras', 'GANs', 'OpenCV', 'UNet++'];

const experience = {
  role: 'Associate',
  company: 'KFintech Solutions Pvt. Ltd.',
  location: 'Hyderabad, India',
  duration: 'July 2025 — Present',
  highlights: [
    'Supporting critical financial operations and client servicing across multiple complex business processes.',
    'Ensuring strict regulatory compliance and absolute accuracy in investor records management and financial reporting workflows.',
    'Collaborating extensively with cross-functional technical and operational teams to deliver timely, quality-driven enterprise outcomes.',
    'Continuously building deep knowledge of financial products, identifying opportunities for process automation, and enhancing investor servicing pipelines.',
    'Analyzing workflow bottlenecks to assist in implementing basic script-based automation, increasing data processing throughput.',
    'Utilizing database tools to query, verify, and reconcile large volumes of transactional records with zero tolerance for discrepancies.',
  ],
};

const stats = [
  { number: '2', label: 'Projects Built' },
  { number: '5+', label: 'Technologies' },
  { number: '1+', label: 'Years Experience' },
  { number: '7.5', label: 'MCA CGPA' },
];

const achievements = [
  {
    icon: 'fas fa-trophy',
    title: '1st Prize — Vignan Mahotsav (2023)',
    detail: 'Led the team to absolute victory with a flawless theme execution and stage choreography.',
  },
  {
    icon: 'fas fa-medal',
    title: '2nd Prize — Vignan Mahotsav (2024)',
    detail: 'Maintained the podium streak against fierce regional competition.',
  },
  {
    icon: 'fas fa-crown',
    title: '1st Prize: Fashion Walk — KLU Surabhi Event',
    detail: 'Dominated the runway at KL University, capturing top honors for style, rhythm, and stage presence.',
  },
  {
    icon: 'fas fa-star',
    title: '1st Prize — Department Fest Fashion Show',
    detail: 'Choreographed and anchored the winning walk to capture the overall department crown.',
  },
];
---

<BaseLayout title="Home">
  <!-- ==================== HERO ==================== -->
  <section class="hero">
    <div class="hero-bg-shapes">
      <div class="hero-shape hero-shape-1"></div>
      <div class="hero-shape hero-shape-2"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name">T. Jagadeesh Kumar</h1>
        <p class="hero-subtitle">
          Associate Software Engineer at <span class="hero-highlight">Ary Technologies</span>
        </p>
        <p class="hero-bio">
          Just a cool, easygoing guy who balances a sharp sense of style with a
          dedication to my work. Grounded by where I come from, powered by big
          ambitions, and always keeping it real.
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">
            <i class="fas fa-code"></i> View My Work
          </a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="profile-ring">
          <div class="profile-ring-glow"></div>
          <img
            src="/images/profile.jpg"
            alt="T. Jagadeesh Kumar"
            class="profile-image"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
          />
          <div class="profile-fallback" style="display:none;">
            <i class="fas fa-user"></i>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT ME ==================== -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">About Me</h2>
        <div class="section-line"></div>
      </div>

      <div class="about-grid">
        <div class="about-text-card">
          <h3 class="card-heading"><i class="fas fa-heart"></i> Beyond the Screen</h3>
          <p>
            Hailing from the quiet town of Etukur in Guntur, Andhra Pradesh, I
            carry the true spirit of a middle-class boy&mdash;grounded, resilient,
            and unapologetically real. Beyond the professional hustle, I'm a
            simple, cool guy who believes that life is best measured by the happy
            moments and the people you share them with.
          </p>
          <p>
            My family is my ultimate anchor; there is nothing better than the
            quiet comfort, laughter, and grounding conversations back home. On
            the flip side, my friends are my absolute fuel. From spontaneous
            roadside tea chats to running the campus like we owned it, making
            memories and sharing laughs with the boys is what keeps life vibrant.
          </p>
          <p>
            No pretense, no fluff&mdash;just a small-town dreamer navigating life
            with a sharp sense of style, casual confidence, and a tight-knit
            circle.
          </p>
        </div>

        <div class="education-stack">
          <h3 class="card-heading" style="margin-bottom: 0.25rem;"><i class="fas fa-graduation-cap"></i> Education</h3>
          {education.map((edu) => (
            <div class="education-card">
              <div class="edu-icon">
                <i class="fas fa-graduation-cap"></i>
              </div>
              <div class="edu-details">
                <h4 class="edu-degree">{edu.degree}</h4>
                <p class="edu-institution">{edu.institution}</p>
                <div class="edu-meta">
                  <span class="edu-period">
                    <i class="far fa-calendar-alt"></i> {edu.period}
                  </span>
                  <span class="edu-cgpa">
                    <i class="fas fa-star"></i> CGPA: {edu.cgpa}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="stats-row">
        {stats.map((stat) => (
          <div class="stat-pill">
            <span class="stat-number">{stat.number}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TECHNICAL SKILLS ==================== -->
  <section class="section section-alt" id="skills">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Technical Skills</h2>
        <div class="section-line"></div>
      </div>

      <!-- Featured full-width card -->
      <div class="skill-card skill-card-featured">
        <div class="skill-card-header">
          <i class={featuredSkill.icon}></i>
          <h3>{featuredSkill.category}</h3>
        </div>
        <div class="skill-tags">
          {featuredSkill.items.map((item) => (
            <span class="skill-tag">{item}</span>
          ))}
        </div>
      </div>

      <!-- Standard grid -->
      <div class="skills-grid">
        {skillCategories.map((skill) => (
          <div class="skill-card">
            <div class="skill-card-header">
              <i class={skill.icon}></i>
              <h3>{skill.category}</h3>
            </div>
            <div class="skill-tags">
              {skill.items.map((item) => (
                <span class="skill-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED PROJECT ==================== -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Featured Project</h2>
        <div class="section-line"></div>
      </div>

      <div class="project-card">
        <div class="project-card-accent"></div>
        <div class="project-card-body">
          <div class="project-card-top">
            <div class="project-icon">
              <i class="fas fa-microscope"></i>
            </div>
            <div class="project-badge">Academic Research</div>
          </div>

          <h3 class="project-title">
            Enhancing Salt Segmentation in Seismic Images Using UNet++ and GANs
          </h3>

          <div class="project-tech-tags">
            {techTags.map((tag) => (
              <span class="tech-tag">{tag}</span>
            ))}
          </div>

          <ul class="project-highlights">
            {projectHighlights.map((point) => (
              <li>{point}</li>
            ))}
          </ul>

          <div class="project-metrics">
            <div class="metric">
              <i class="fas fa-bullseye"></i>
              <span>IoU &amp; Dice Coefficient</span>
            </div>
            <div class="metric">
              <i class="fas fa-chart-line"></i>
              <span>Precision &amp; Recall</span>
            </div>
            <div class="metric">
              <i class="fas fa-compress-arrows-alt"></i>
              <span>Hybrid Loss (Dice + BCE)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ACHIEVEMENTS ==================== -->
  <section class="section" id="achievements">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Runway &amp; Leadership</h2>
        <div class="section-line"></div>
      </div>

      <p class="achievements-intro">
        Stepping away from the desk and onto the stage&mdash;driving creative
        vision, choreography, and winning streaks as the college Fashion Team
        Lead.
      </p>

      <div class="achievements-grid">
        {achievements.map((a) => (
          <div class="achievement-card">
            <div class="achievement-icon">
              <i class={a.icon}></i>
            </div>
            <div class="achievement-content">
              <h4 class="achievement-title">{a.title}</h4>
              <p class="achievement-detail">{a.detail}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="achievements-cta">
        <a href="/achievements" class="btn btn-outline">
          <i class="fas fa-trophy"></i> View All Achievements
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== EXPERIENCE ==================== -->
  <section class="section section-alt" id="experience">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Experience</h2>
        <div class="section-line"></div>
      </div>

      <div class="exp-card">
        <div class="exp-timeline">
          <div class="exp-timeline-dot"></div>
          <div class="exp-timeline-line"></div>
        </div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-role">{experience.role}</h3>
              <p class="exp-company">{experience.company}</p>
            </div>
            <div class="exp-meta">
              <span class="exp-location"><i class="fas fa-map-marker-alt"></i> {experience.location}</span>
              <span class="exp-duration"><i class="far fa-calendar-alt"></i> {experience.duration}</span>
            </div>
          </div>
          <ul class="exp-highlights">
            {experience.highlights.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CERTIFICATIONS ==================== -->
  <section class="section section-alt" id="certifications">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Certifications</h2>
        <div class="section-line"></div>
      </div>

      <div class="cert-grid">
        <div class="cert-card">
          <div class="cert-icon">
            <i class="fas fa-award"></i>
          </div>
          <div class="cert-info">
            <h4>Python Programming</h4>
            <p class="cert-issuer">CodeChef</p>
            <p class="cert-year">2023</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CONTACT ==================== -->
  <section class="section" id="contact">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Get in Touch</h2>
        <div class="section-line"></div>
      </div>

      <div class="contact-row">
        <a href="mailto:tjagadeesh2903@gmail.com" class="contact-link">
          <span class="contact-icon-wrap">
            <i class="fas fa-envelope"></i>
          </span>
          <span class="contact-label">Email</span>
          <span class="contact-value">tjagadeesh2903@gmail.com</span>
        </a>

        <a href="tel:+916303431386" class="contact-link">
          <span class="contact-icon-wrap">
            <i class="fas fa-phone-alt"></i>
          </span>
          <span class="contact-label">Phone</span>
          <span class="contact-value">+91 6303431386</span>
        </a>

        <a href="https://github.com/" target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="contact-icon-wrap">
            <i class="fab fa-github"></i>
          </span>
          <span class="contact-label">GitHub</span>
          <span class="contact-value">github.com/jagadeesh</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===========================================================
     HERO
     =========================================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(
      160deg,
      #0d0d0c 0%,
      rgba(244, 196, 20, 0.03) 45%,
      #0d0d0c 100%
    );
  }

  .hero-bg-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.10;
  }

  .hero-shape-1 {
    width: 500px;
    height: 500px;
    background: var(--gold);
    top: -8%;
    right: -5%;
  }

  .hero-shape-2 {
    width: 320px;
    height: 320px;
    background: var(--gold-light);
    bottom: 5%;
    left: -4%;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    padding-top: 6rem;
    position: relative;
    z-index: 1;
  }

  /* -- Left column -- */
  .hero-content {
    flex: 1;
    max-width: 620px;
  }

  .hero-greeting {
    font-size: 1.1rem;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .hero-highlight {
    color: var(--gold);
    font-weight: 600;
  }

  .hero-bio {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.85;
    margin-bottom: 2.25rem;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* -- Buttons -- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2.25rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    border: 2px solid transparent;
  }

  .btn-primary {
    background: var(--gradient-primary);
    color: #0d0d0c;
    border-color: var(--gold);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(244, 196, 20, 0.3);
    color: #0d0d0c;
  }

  /* -- Right column / profile image -- */
  .hero-visual {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .profile-ring {
    position: relative;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    padding: 6px;
    background: var(--gradient-primary);
  }

  .profile-ring-glow {
    position: absolute;
    inset: -14px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244, 196, 20, 0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: #1a1a18;
    position: relative;
    z-index: 1;
  }

  .profile-fallback {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #1a1a18;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    color: var(--gold);
    position: relative;
    z-index: 1;
  }

  /* ===========================================================
     SECTION UTILITIES
     =========================================================== */
  .section {
    padding: 5rem 0;
  }

  .section-alt {
    background: rgba(22, 22, 20, 0.45);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .section-line {
    width: 60px;
    height: 3px;
    background: var(--gradient-primary);
    margin: 0 auto;
    border-radius: 3px;
  }

  /* ===========================================================
     ABOUT & EDUCATION
     =========================================================== */
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .about-text-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
  }

  .card-heading {
    font-size: 1.3rem;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .about-text-card p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-text-card p:last-child {
    margin-bottom: 0;
  }

  .education-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .education-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .education-card:hover {
    border-color: var(--gold-border-strong);
    box-shadow: var(--elevation-2);
  }

  .edu-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: var(--gold-bg-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .edu-degree {
    font-size: 1.05rem;
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .edu-institution {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .edu-meta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .edu-meta span {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .edu-meta span i {
    color: var(--gold);
    font-size: 0.8rem;
  }

  .edu-cgpa {
    font-weight: 600;
    color: var(--gold) !important;
  }

  /* ===========================================================
     STATS ROW
     =========================================================== */
  .stats-row {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .stat-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 2rem;
    min-width: 130px;
    transition: border-color 0.3s ease;
  }

  .stat-pill:hover {
    border-color: var(--gold-border-strong);
  }

  .stat-number {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  /* ===========================================================
     SKILLS
     =========================================================== */
  .skill-card-featured {
    margin-bottom: 1.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .skill-card:hover {
    border-color: var(--gold-border-strong);
    transform: translateY(-4px);
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-card-header i {
    font-size: 1.3rem;
    color: var(--gold);
  }

  .skill-card-header h3 {
    font-size: 1rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: var(--bg-dark);
    color: var(--text-secondary);
    padding: 6px 16px;
    border-radius: 8px;
