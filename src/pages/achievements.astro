---
import BaseLayout from '../layouts/BaseLayout.astro';

const prizes = [
  {
    icon: 'fas fa-trophy',
    title: '1st Prize — Vignan Mahotsav (2023)',
    detail: 'Led the team to absolute victory with a flawless theme execution and stage choreography.',
    year: '2023',
  },
  {
    icon: 'fas fa-medal',
    title: '2nd Prize — Vignan Mahotsav (2024)',
    detail: 'Maintained the podium streak against fierce regional competition.',
    year: '2024',
  },
  {
    icon: 'fas fa-crown',
    title: '1st Prize: Fashion Walk — KLU Surabhi Event',
    detail: 'Dominated the runway at KL University, capturing top honors for style, rhythm, and stage presence.',
    year: '2024',
  },
  {
    icon: 'fas fa-star',
    title: '1st Prize — Department Fest Fashion Show',
    detail: 'Choreographed and anchored the winning walk to capture the overall department crown.',
    year: '2024',
  },
];
---

<BaseLayout title="Achievements">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero-title">Runway &amp; Leadership</h1>
      <p class="page-hero-description">
        Stepping away from the desk and onto the stage&mdash;driving creative
        vision, choreography, and winning streaks as the college Fashion Team
        Lead.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="trophy-grid">
        {prizes.map((prize) => (
          <div class="trophy-card">
            <div class="trophy-card-glow"></div>
            <div class="trophy-icon-wrap">
              <i class={prize.icon}></i>
            </div>
            <div class="trophy-year">{prize.year}</div>
            <h3 class="trophy-title">{prize.title}</h3>
            <p class="trophy-detail">{prize.detail}</p>
            <div class="trophy-accent-line"></div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .trophy-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .trophy-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 2.5rem 2rem;
    text-align: center;
    overflow: hidden;
    transition: border-color 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
  }

  .trophy-card:hover {
    border-color: var(--gold);
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(244, 196, 20, 0.12),
                0 0 0 1px rgba(244, 196, 20, 0.08);
  }

  .trophy-card-glow {
    position: absolute;
    top: -60%;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244, 196, 20, 0.08) 0%, transparent 70%);
    pointer-events: none;
    transition: opacity 0.4s ease;
    opacity: 0;
  }

  .trophy-card:hover .trophy-card-glow {
    opacity: 1;
  }

  .trophy-icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #0d0d0c;
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 24px rgba(244, 196, 20, 0.2);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .trophy-card:hover .trophy-icon-wrap {
    transform: scale(1.1) rotate(-5deg);
    box-shadow: 0 0 36px rgba(244, 196, 20, 0.35);
  }

  .trophy-year {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--gold);
    background: var(--gold-bg-strong);
    border: 1px solid var(--gold-border-strong);
    border-radius: 4px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .trophy-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .trophy-detail {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .trophy-accent-line {
    width: 40px;
    height: 3px;
    background: var(--gradient-primary);
    border-radius: 3px;
    margin: 1.5rem auto 0;
    transition: width 0.4s ease;
    position: relative;
    z-index: 1;
  }

  .trophy-card:hover .trophy-accent-line {
    width: 80px;
  }

  @media (max-width: 768px) {
    .trophy-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }
</style>
